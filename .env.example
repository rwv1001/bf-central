# =============================================================================
# bf-central environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# PostgreSQL password
DB_PASSWORD=change_this_strong_password

# Your DuckDNS (or other) domain for this central server
# Caddy will obtain a Let's Encrypt certificate for this domain automatically.
# Ports 80 and 443 must be publicly accessible on this server.
CENTRAL_DOMAIN=bf-central.duckdns.org

# Admin key — used once per site to register it and obtain its API key.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(40))"
ADMIN_KEY=change_this_admin_key

# =============================================================================
# Optional
# =============================================================================

# Postgres database and user names (defaults shown — safe to leave as-is)
# DB_NAME=bf_central
# DB_USER=central_user

# Number of Gunicorn worker processes (default 2 is fine for most deployments)
# GUNICORN_WORKERS=2
